{
  "manifest_version": 3,

  "name": "Pinterest Board Extractor",

  "version": "1.0",

  "description": "Extract image URLs from Pinterest boards.",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://*.pinterest.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  }
}